# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=a25_db

# TypeORM auto-sync. Leave true for fresh setups so the seed script can
# scaffold the schema. Once the schema is established, set this to false
# and run `pnpm run migrate` for any future schema changes — TypeORM's
# automatic enum migrations are unsafe.
DB_SYNCHRONIZE=false

# Keep DATABASE_URL in sync for any tool that uses it (e.g. Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/a25_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# System Admin (used by seed script)
SYSTEM_ADMIN_EMAIL=admin@system.com
SYSTEM_ADMIN_PASSWORD=admin123
SYSTEM_ADMIN_NAME=System Admin


# ----- Translation Provider (optional) ---------------------------------------
# Pick ONE of the following. If none is set, the mock translator runs and
# annotates messages with the target language flag/code so you can verify the
# end-to-end UI flow without API keys.

# OpenAI (best context awareness for hospitality)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# DeepL (fast, high quality for major languages)
# DEEPL_API_KEY=

# Google Translate (broad language coverage)
GOOGLE_TRANSLATE_API_KEY=


# ----- Cloudinary (image hosting) --------------------------------------------
# Used for hotel logos / banners / gallery and service cover images.
# Sign up free at https://cloudinary.com and grab the values from the dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix so uploads are grouped per-environment
CLOUDINARY_FOLDER=a25
